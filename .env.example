PORT=3001
NODE_ENV=development

# MySQL — على Railway استخدم Variable Reference لـ MYSQL_URL
DATABASE_URL=mysql://user:password@localhost:3306/card_platform
# أو مباشرة من Railway:
# MYSQL_URL=mysql://root:password@host:port/railway

# JWT
JWT_SECRET=change-this-to-a-long-random-secret

# بوابة SMS — جوال المنصة (نفس الرمز يُدخل في التطبيق)
# استخدم رمز عشوائي طويل (32+ حرف) — مثال: openssl rand -hex 32
SMS_GATEWAY_TOKEN=change-this-gateway-token-to-a-long-random-string

# اختياري: ربط الجوال المسموح فقط (Android ID يظهر في التطبيق عند الإعداد)
SMS_GATEWAY_DEVICE_ID=

# Frontend (Vite)
CLIENT_URL=http://localhost:5173,http://127.0.0.1:5173

# MikroTik — تُخزَّن هنا فقط على السيرفر (دومين خارجي يعمل بدون نفس الشبكة المحلية)
# مهلة جلب مخزون الراوتر الكامل بالثواني (افتراضي 180)
# MIKROTIK_INVENTORY_TIMEOUT=180
# مثال: hslink.pro على المنفذ 7227
MIKROTIK_HOST=hslink.pro
MIKROTIK_PORT=7227
MIKROTIK_USER=admin
# ضع كلمة المرور بين quotes إذا فيها رموز مثل $
MIKROTIK_PASSWORD="your-password-here"
MIKROTIK_USE_TLS=false
# اختياري فقط — لتجاوز عميل User Manager المكتشف تلقائياً من الراوتر
# MIKROTIK_UM_CUSTOMER=admin
